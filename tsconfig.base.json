{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@ahmedabadcar/shared": [
        "packages/shared/src/index.ts"
      ],
      "@ahmedabadcar/shared/*": [
        "packages/shared/src/*"
      ]
    }
  }
}

