{
  "name": "ahmedabadcar-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev:api": "pnpm --filter @ahmedabadcar/api dev",
    "dev:mobile": "pnpm --filter @ahmedabadcar/mobile start",
    "dev": "pnpm -r --parallel --filter @ahmedabadcar/api --filter @ahmedabadcar/mobile dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "format": "pnpm -r format"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
