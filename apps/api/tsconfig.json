{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "types": [
      "node",
      "vitest/globals"
    ],
    "skipLibCheck": true,
    "noEmit": false,
    "declaration": false
  },
  "include": [
    "src",
    "../../packages/shared/src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
